digraph database_schema {
  graph [rankdir=LR, splines=ortho, overlap=false, fontsize=18];
  node [shape=plain, fontname="Arial"];
  edge [fontname="Arial", fontsize=10];
  label="starostina-leanedu — full database schema";
  labelloc=t;

  "ai_daily_usage" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>ai_daily_usage</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;ai_daily_usage_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">usage_date</TD><TD ALIGN="LEFT">date</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE</TD></TR><TR><TD ALIGN="LEFT">used_tokens</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT 0</TD></TR></TABLE>>];
  "ai_generations" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>ai_generations</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;ai_generations_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">user_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → users.id</TD></TR><TR><TD ALIGN="LEFT">lecture_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">FK → lectures.id</TD></TR><TR><TD ALIGN="LEFT">status</TD><TD ALIGN="LEFT">character varying(32)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">model</TD><TD ALIGN="LEFT">character varying(100)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">prompt_hash</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">response_json</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">prompt_tokens</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">completion_tokens</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">total_tokens</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamp with time zone</TD><TD ALIGN="LEFT">NOT NULL</TD></TR></TABLE>>];
  "attempt_answers" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>attempt_answers</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;attempt_answers_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">attempt_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → test_attempts.id</TD></TR><TR><TD ALIGN="LEFT">question_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → questions.id</TD></TR><TR><TD ALIGN="LEFT">selected_option_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → question_options.id</TD></TR><TR><TD ALIGN="LEFT">correct</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">awarded_points</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR></TABLE>>];
  "flyway_schema_history" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>flyway_schema_history</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">installed_rank</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">PK, NOT NULL</TD></TR><TR><TD ALIGN="LEFT">version</TD><TD ALIGN="LEFT">character varying(50)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">description</TD><TD ALIGN="LEFT">character varying(200)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">type</TD><TD ALIGN="LEFT">character varying(20)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">script</TD><TD ALIGN="LEFT">character varying(1000)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">checksum</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">installed_by</TD><TD ALIGN="LEFT">character varying(100)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">installed_on</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT now()</TD></TR><TR><TD ALIGN="LEFT">execution_time</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">success</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT">NOT NULL</TD></TR></TABLE>>];
  "group_students" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>group_students</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;group_students_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">group_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE, FK → groups.id</TD></TR><TR><TD ALIGN="LEFT">student_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE, FK → users.id</TD></TR></TABLE>>];
  "groups" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>groups</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;groups_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">code</TD><TD ALIGN="LEFT">character varying(100)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE</TD></TR><TR><TD ALIGN="LEFT">name</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">course_year</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR></TABLE>>];
  "learning_tests" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>learning_tests</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;learning_tests_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">title</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">description</TD><TD ALIGN="LEFT">character varying(800)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">lecture_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">FK → lectures.id</TD></TR><TR><TD ALIGN="LEFT">published</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT false</TD></TR><TR><TD ALIGN="LEFT">time_limit_min</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">attempts_limit</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">created_by</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → users.id</TD></TR><TR><TD ALIGN="LEFT">min_score_3</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT 2</TD></TR><TR><TD ALIGN="LEFT">min_score_4</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT 3</TD></TR><TR><TD ALIGN="LEFT">min_score_5</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT 4</TD></TR><TR><TD ALIGN="LEFT">subject_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">FK → subjects.id</TD></TR></TABLE>>];
  "lectures" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>lectures</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;lectures_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">title</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">summary</TD><TD ALIGN="LEFT">character varying(800)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">content</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">published</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT false</TD></TR><TR><TD ALIGN="LEFT">created_by</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → users.id</TD></TR><TR><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamp with time zone</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">timestamp with time zone</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">subject_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">FK → subjects.id</TD></TR></TABLE>>];
  "question_options" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>question_options</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;question_options_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">question_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → questions.id</TD></TR><TR><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">correct</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT">NOT NULL</TD></TR></TABLE>>];
  "questions" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>questions</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;questions_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">test_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → learning_tests.id</TD></TR><TR><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">points</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">sort_order</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR></TABLE>>];
  "subjects" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>subjects</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;subjects_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">code</TD><TD ALIGN="LEFT">character varying(100)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE</TD></TR><TR><TD ALIGN="LEFT">name</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE</TD></TR></TABLE>>];
  "teaching_assignments" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>teaching_assignments</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;teaching_assignments_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">group_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE, FK → groups.id</TD></TR><TR><TD ALIGN="LEFT">subject_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE, FK → subjects.id</TD></TR><TR><TD ALIGN="LEFT">teacher_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE, FK → users.id</TD></TR></TABLE>>];
  "test_assignments" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>test_assignments</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;test_assignments_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">test_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → learning_tests.id</TD></TR><TR><TD ALIGN="LEFT">group_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → groups.id</TD></TR><TR><TD ALIGN="LEFT">due_at</TD><TD ALIGN="LEFT">timestamp with time zone</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">active</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT true</TD></TR></TABLE>>];
  "test_attempts" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>test_attempts</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;test_attempts_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">test_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → learning_tests.id</TD></TR><TR><TD ALIGN="LEFT">student_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → users.id</TD></TR><TR><TD ALIGN="LEFT">started_at</TD><TD ALIGN="LEFT">timestamp with time zone</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">submitted_at</TD><TD ALIGN="LEFT">timestamp with time zone</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">score</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT 0</TD></TR><TR><TD ALIGN="LEFT">max_score</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT 0</TD></TR><TR><TD ALIGN="LEFT">status</TD><TD ALIGN="LEFT">character varying(32)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR></TABLE>>];
  "users" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>users</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;users_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">email</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE</TD></TR><TR><TD ALIGN="LEFT">password_hash</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">full_name</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">role</TD><TD ALIGN="LEFT">character varying(32)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">active</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT true</TD></TR><TR><TD ALIGN="LEFT">avatar_url</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT"></TD></TR></TABLE>>];

  "ai_generations" -> "lectures" [label="lecture_id → id"];
  "ai_generations" -> "users" [label="user_id → id"];
  "attempt_answers" -> "test_attempts" [label="attempt_id → id"];
  "attempt_answers" -> "questions" [label="question_id → id"];
  "attempt_answers" -> "question_options" [label="selected_option_id → id"];
  "group_students" -> "groups" [label="group_id → id"];
  "group_students" -> "users" [label="student_id → id"];
  "learning_tests" -> "users" [label="created_by → id"];
  "learning_tests" -> "lectures" [label="lecture_id → id"];
  "learning_tests" -> "subjects" [label="subject_id → id"];
  "lectures" -> "users" [label="created_by → id"];
  "lectures" -> "subjects" [label="subject_id → id"];
  "question_options" -> "questions" [label="question_id → id"];
  "questions" -> "learning_tests" [label="test_id → id"];
  "teaching_assignments" -> "groups" [label="group_id → id"];
  "teaching_assignments" -> "subjects" [label="subject_id → id"];
  "teaching_assignments" -> "users" [label="teacher_id → id"];
  "test_assignments" -> "groups" [label="group_id → id"];
  "test_assignments" -> "learning_tests" [label="test_id → id"];
  "test_attempts" -> "users" [label="student_id → id"];
  "test_attempts" -> "learning_tests" [label="test_id → id"];
}